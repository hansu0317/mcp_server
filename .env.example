# DB (데모: PostgreSQL Docker)
DATABASE_URL=postgresql://crm_user:crm_pass@localhost:5432/crm_db

# LLM 설정: groq 또는 claude
LLM_PROVIDER=groq

# Groq (현재 사용 - 무료)
GROQ_API_KEY=gsk_your_groq_key_here

# Claude API (최종 테스트 시 사용 - LLM_PROVIDER=claude 로 변경)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# MCP
MCP_SERVER_PATH=mcp_server/server.py
MAX_QUERY_ROWS=100

# 향후 MS Dataverse 전환 시 사용
# DATAVERSE_URL=https://yourorg.crm.dynamics.com
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
